{
  "functions": {
    "api/api.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/test_php.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api",
      "dest": "/api/api.php"
    },
    {
      "src": "/index",
      "dest": "/api/index.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
